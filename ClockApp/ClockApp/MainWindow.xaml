<Window x:Class="ClockApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClockApp"
        Title="Аналоговые Часы с Будильником" Height="450" Width="650">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <!-- Левая часть для адаптивных часов -->
            <ColumnDefinition Width="1*"/>
            <!-- Правая часть для панели настроек -->
        </Grid.ColumnDefinitions>

        <!-- Контейнер для часов. Меняй размер самого окна — часы будут плавно масштабироваться! -->
        <Border Background="#EAEAEA" Margin="15" CornerRadius="10">
            <local:ClockControl x:Name="MyClock" 
                                ArrowsColor="Black" 
                                ClockBackendColor="White"
                                AlarmTriggered="MyClock_AlarmTriggered"/>
        </Border>

        <!-- Панель управления для демонстрации на сдаче лабораторной -->
        <StackPanel Grid.Column="1" Margin="15" VerticalAlignment="Center">
            <TextBlock Text="Настройки часов" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" HorizontalAlignment="Center"/>

            <TextBlock Text="Цвет циферблата:" Margin="0,5,0,2"/>
            <ComboBox x:Name="ComboFaceColor" SelectionChanged="ComboFaceColor_SelectionChanged" SelectedIndex="0">
                <ComboBoxItem Content="White"/>
                <ComboBoxItem Content="LightBlue"/>
                <ComboBoxItem Content="LightGreen"/>
                <ComboBoxItem Content="LightGray"/>
            </ComboBox>

            <TextBlock Text="Цвет стрелок:" Margin="0,10,0,2"/>
            <ComboBox x:Name="ComboArrowsColor" SelectionChanged="ComboArrowsColor_SelectionChanged" SelectedIndex="0">
                <ComboBoxItem Content="Black"/>
                <ComboBoxItem Content="DarkBlue"/>
                <ComboBoxItem Content="Purple"/>
                <ComboBoxItem Content="Red"/>
            </ComboBox>

            <Separator Margin="0,20,0,20"/>

            <TextBlock Text="Время будильника (ЧЧ:ММ):" Margin="0,5,0,2"/>
            <TextBox x:Name="TxtAlarmTime" Text="12:00" Padding="4" FontSize="14" HorizontalContentAlignment="Center"/>

            <CheckBox x:Name="ChkAlarmEnabled" Content="Включить будильник" Margin="0,10,0,0" FontSize="12"
                      Checked="ChkAlarmEnabled_Checked" Unchecked="ChkAlarmEnabled_Unchecked"/>
        </StackPanel>
    </Grid>
</Window>